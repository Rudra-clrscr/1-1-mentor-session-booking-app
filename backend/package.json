{
  "name": "mentor-backend",
  "version": "1.0.0",
  "description": "Backend for 1-on-1 Mentor-Student Platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "start": "node -r module-alias/register dist/index.js",
    "migrate": "ts-node -r tsconfig-paths/register src/migrations.ts",
    "seed": "ts-node -r tsconfig-paths/register src/seed.ts",
    "migrate:seed": "npm run migrate && npm run seed",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "collab:server": "ts-node -r tsconfig-paths/register src/scripts/start-collab-server.ts",
    "collab:server:dev": "nodemon --exec ts-node -r tsconfig-paths/register src/scripts/start-collab-server.ts",
    "dev:all": "npm run dev & npm run collab:server:dev"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.0",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "module-alias": "^2.3.4",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.10",
    "pg": "^8.11.3",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "y-protocols": "^1.0.6",
    "y-websocket": "^1.5.0",
    "yjs": "^13.6.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.0"
  },
  "_moduleAliases": {
    "@": "dist"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
